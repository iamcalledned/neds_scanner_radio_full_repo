# Scanner Web App Environment Configuration

# --- Service Identity ---
SERVICE_NAME=scanner_web
APP_ENV=production
LOG_LEVEL=INFO

# --- Log File ---
# Absolute path to the log file. Directory must exist and be writable.
LOG_FILE=

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- Flask ---
# FLASK_SECRET_KEY=change-me-to-something-secret

# --- Google Maps (Heat Map page) ---
# Get a key at https://developers.google.com/maps/documentation/javascript/get-api-key
# Enable: Maps JavaScript API. Restrict key to your domain for production.
# GOOGLE_MAPS_API_KEY=
