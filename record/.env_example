# Scanner Recorder Environment Configuration
#
# Copy this file to .env and fill in your paths:
#   cp .env_example .env

# --- Paths ---
ARCHIVE_BASE=/path/to/scanner_archive
LOG_DIR=/path/to/logs/recorder_logs
TRANSCRIBE_QUEUE=/tmp/transcribe_queue.txt

# --- Audio ---
SAMPLE_RATE=48000

# --- Silence Segmentation (sox) ---
START_DUR=0.05
STOP_DUR=3.0
THRESH=0.2%
LEAD_PAD=0.15
