# Scanner Recorder Environment Configuration

# --- Paths ---
ARCHIVE_BASE=/home/ned/data/scanner_calls/scanner_archive

# Directory where dated log files are written.
# Files will be named: recorder_YYYY-MM-DD.log
LOG_DIR=/home/ned/data/scanner_calls/logs/recorder_logs

TRANSCRIBE_QUEUE=/tmp/transcribe_queue.txt

# --- Audio ---
SAMPLE_RATE=48000

# --- Silence Segmentation (sox) ---
START_DUR=0.05
STOP_DUR=3.0
THRESH=0.2%
LEAD_PAD=0.15

CHANNELS_FILE=/home/ned/Documents/neds_scanner_radio_full_pipeline_with_git/config/scanner_channels.conf
