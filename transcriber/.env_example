# Transcriber Stack Environment Configuration
#
# Copy this file to .env and fill in your paths:
#   cp .env_example .env

# --- Logging ---
LOG_DIR=/path/to/logs/transcriber_logs
LOG_LEVEL=INFO

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- MCP Server ---
MCP_URL=http://127.0.0.1:8000/mcp

# --- CUDA ---
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- Archive ---
ARCHIVE_BASE=/path/to/scanner_archive

# --- Whisper Model ---
WHISPER_MODEL_DIR=/path/to/your/trained_whisper_model
